<style>
form{
	display:block;
	margin-bottom:1em;
}


textarea, input[type="text"], input[type="number"], input[type="search"]{
	padding:0.5em;
	font-family: "Courier New", monospace;
	font-size:14px;
}

input[type="submit"], input[type="button"]{
	padding:0.5em;
}

/*
input[type='checkbox']:before {
	background-color:#FFCC00;
}
*/

.checkbox_label{
	margin-left:-5px; 
	margin-right:10px;
	vertical-align:3px;
	cursor:pointer;
}

select{
	padding:0.5em;
}

.form_cell{
	display:inline-block;
}
</style>

<script>
function submit_domains_form(){

	// convert email to base64 encode to avoi a google PII warning
	// document.getElementById('whois_email_box').value=btoa(document.getElementById('whois_email_box').value);
	
	return true;
	
}
</script>

<form name="domains_form" id="domains_form" method="get" onSubmit="submit_domains_form();">

<!--
<input type="search" name="domain_name_box" id="domain_name_box" value="" placeholder="search in name" TextMode="MultiLine">
-->

<span class="form_cell">
search in name (e.g <em><strong>*.com</strong></em><strong></strong>)<br />
<textarea style="vertical-align:bottom; margin-bottom:-7px;" name="domain_name_box" rows="1" id="domain_name_box" placeholder="search name"></textarea>
</span>

<span class="form_cell">
search #2 in name<br />
<textarea style="vertical-align:bottom; margin-bottom:-7px;" name="domain_name_box_2" rows="1" id="domain_name_box_2" placeholder="search name #2"></textarea>
</span>

<span class="form_cell">
whois status<br />
<input type="search" name="whois_status_box" id="whois_status_box" style="width:9em;" value="" placeholder="status">
</span>




<span class="form_cell">
max records<br />
<input type="number" name="maximum_records_box" id="maximum_records_box" style="width:5em;" value="500" title="records" placeholder="maximum records">
</span>

<span class="form_cell" title="maximum domain length">
chars<br />
<input type="number" name="maximum_characters_box" id="maximum_characters_box" size="2" style="width:4em;" value="" title="maximum characters" placeholder="chars">
</span>




<span class="form_cell" title="availability">
registration availability<br />
<select name="availability_box" id="availability_box">
  <option>any</option>
  <option value="1" >true</option>
  <option value="0" >false</option>
</select>
</span>


<br>


<input type="checkbox" name="can_contain_letters_box" id="can_contain_letters_box" value="true" checked>
<label for="can_contain_letters_box" class="checkbox_label">letters</label>


<input type="checkbox" name="can_contain_numbers_box" id="can_contain_numbers_box" value="true" checked>
<label for="can_contain_numbers_box" class="checkbox_label">numbers</label>


<input type="checkbox" name="can_contain_dashes_box" id="can_contain_dashes_box" value="true" checked>
<label for="can_contain_dashes_box" class="checkbox_label">dashes</label>


<input type="button" value="Reset" onClick="window.location='?';" style="margin-top:5px;">

<input type="hidden" name="sort" value="">
<input type="hidden" name="order" value="">

<input type="submit" value="Search" style="margin-top:5px;">


</form>





