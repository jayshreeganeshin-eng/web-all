# Environment Configuration for web-all
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Output Directory
OUTPUT_DIR=./output

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# AI Configuration (Optional)
AI_ENABLED=false
AI_PROVIDER=ollama
AI_MODEL=llama3
AI_BASE_URL=http://localhost:11434
# AI_API_KEY=your-api-key-here  # Required for OpenRouter, Groq, HuggingFace

# Tor Configuration (Optional)
TOR_PROXY=http://127.0.0.1:9050
USE_TOR=false

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Job Configuration
MAX_JOBS=1000
MAX_PAGES_PER_JOB=1000
DEFAULT_DEPTH=2
DEFAULT_CONCURRENCY=5

# Security
SECRET_KEY=change-this-in-production
ALLOWED_HOSTS=*

# Database (for future persistence)
# DATABASE_URL=sqlite:///./web_all.db
